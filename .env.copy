# --- API Credentials ---
# Primary key for the LLM provider (Fallback: HF_TOKEN)
API_KEY="<YOUR_API_KEY>"
HF_TOKEN="<YOUR_HUGGINGFACE_TOKEN>"

# --- LLM Configuration ---
API_BASE_URL="https://router.huggingface.co/v1"
MODEL_NAME="Qwen/Qwen3.5-35B-A3B:novita"

# --- Environment / Docker Configuration ---
# IMAGE_NAME: Docker image tag OR https:// URL of the running environment server.
# The inference script uses this to locate the OpenEnv server.
# Set to the HF Space URL for remote inference, or a local docker image tag.
IMAGE_NAME="https://rajaguru2004-bpo-env.hf.space"
SERVER_URL="http://localhost:7860"
LOCAL_IMAGE_NAME="openenv-bpo:latest"